<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ cold start: background + logo -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="android:windowSplashScreenBackground">#f5f5f5</item>
        <!-- Keep Android 12+ launch splash visually empty so only Capacitor splash is noticeable. -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_blank</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <!-- Setelah splash: pakai tema dengan nav bar hitam (bukan AppTheme Light default). -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
